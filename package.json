{
  "name": "nostr-biometric-auth-utils",
  "version": "0.2.0",
  "type": "module",
  "description": "A utility library for biometric authentication in Nostr applications using WebAuthn.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "examples/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "prepack": "npm run build",
    "start:demo": "node examples/proof_of_concept/simple-server.js"
  },
  "keywords": [
    "nostr",
    "authentication",
    "webauthn",
    "biometric",
    "hardware-security",
    "passkey",
    "maiqr"
  ],
  "author": "vveerrgg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HumanjavaEnterprises/nostr-biometric-auth-utils.git"
  },
  "bugs": {
    "url": "https://github.com/HumanjavaEnterprises/nostr-biometric-auth-utils/issues"
  },
  "homepage": "https://github.com/HumanjavaEnterprises/nostr-biometric-auth-utils#readme",
  "dependencies": {
    "@scure/base": "^2.0.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "nostr-crypto-utils": "file:../nostr-crypto-utils"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
